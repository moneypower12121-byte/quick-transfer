12:["$","div",null,{"className":"space-y-6 mt-8","children":[["$","div",null,{"children":[["$","h4",null,{"className":"font-bold","children":"How long are my files stored?"}],["$","p",null,{"children":"Files are stored temporarily on our servers. You can choose the expiry time during upload, typically ranging from a few minutes to several hours. Once expired, the files are permanently deleted."}]]}],["$","div",null,{"children":[["$","h4",null,{"className":"font-bold","children":"Is there a limit on how many files I can send?"}],["$","p",null,{"children":"No! You can perform as many transfers as you need. Our goal is to provide a reliable, free resource for the global community to share data effortlessly."}]]}],["$","div",null,{"children":[["$","h4",null,{"className":"font-bold","children":"Do I need to install any software?"}],["$","p",null,{"children":"No installation is necessary. QuickTransfer is a purely web-based application that works in any browser. We also offer a PWA (Progressive Web App) for users who want a mobile-app-like experience."}]]}]]}]
