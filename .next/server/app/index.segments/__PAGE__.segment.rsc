9:["$","div",null,{"className":"space-y-6 divide-y divide-gray-100 dark:divide-slate-700","children":[["$","div",null,{"className":"pt-0","children":[["$","p",null,{"className":"font-bold text-gray-800 dark:text-white mb-2","children":"Is it free to use?"}],["$","p",null,{"className":"text-gray-600 dark:text-gray-300 text-sm leading-relaxed","children":"Yes, QuickTransfer is 100% free with no hidden subscriptions or data collection. We believe in open, fast utility for everyone."}]]}],["$","div",null,{"className":"pt-6","children":[["$","p",null,{"className":"font-bold text-gray-800 dark:text-white mb-2","children":"What happens to my files?"}],["$","p",null,{"className":"text-gray-600 dark:text-gray-300 text-sm leading-relaxed","children":"Files are automatically purged from our servers after the chosen expiration time or immediately after the maximum allowed downloads."}]]}],["$","div",null,{"className":"pt-6","children":[["$","p",null,{"className":"font-bold text-gray-800 dark:text-white mb-2","children":"Do I need an account?"}],["$","p",null,{"className":"text-gray-600 dark:text-gray-300 text-sm leading-relaxed","children":"Never. We don't ask for your name, email, or any personal details. Just drag, drop, and share."}]]}]]}]
