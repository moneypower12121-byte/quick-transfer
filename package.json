{
  "name": "quicktransfer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate-icons": "node scripts/generate-icons.cjs",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win --x64"
  },
  "dependencies": {
    "firebase": "^10.14.1",
    "lucide-react": "^0.563.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.18.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.0.0"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.quicktransfer.app",
    "productName": "QuickTransfer",
    "directories": {
      "buildResources": "build",
      "output": "dist_electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "public/**"
    ],
    "win": {
      "target": ["nsis"],
      "publisherName": "QuickTransfer"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
